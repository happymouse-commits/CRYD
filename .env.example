# ===== CRYD 项目环境变量配置 =====
# 复制此文件为 .env 并填入实际值
# 注意: .env 文件已加入 .gitignore，不会被提交到版本控制

# ===== 大模型 API（DeepSeek V4 Pro）=====
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_MODEL=deepseek-chat

# ===== 星火嵌入模型（可选，未来替换本地哈希向量）=====
# EMBEDDING_API_URL=https://emb.xf-yun.com/v1/embeddings
# EMBEDDING_API_KEY=your_spark_embedding_key
# EMBEDDING_MODEL=embedding-v1

# ===== 知识库导入路径 =====
KNOWLEDGE_BASE_PATH=./data/knowledge-base
