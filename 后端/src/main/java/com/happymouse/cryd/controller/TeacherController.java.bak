/*
@RestController
@RequestMapping("/api/teacher")
public class TeacherController {

    private static final Logger log = LoggerFactory.getLogger(TeacherController.class);

    private final TeacherRepository teacherRepository;
    private final CourseRepository courseRepository;
    private final ChapterRepository chapterRepository;
    private final ChapterProgressRepository progressRepository;
    private final SysUserRepository sysUserRepository;
    private final QuestionRepository questionRepository;
    private final AgentOrchestrator orchestrator;
    private final SparkClient sparkClient;

    public TeacherController(TeacherRepository teacherRepository,
                             CourseRepository courseRepository,
                             ChapterRepository chapterRepository,
                             ChapterProgressRepository progressRepository,
                             SysUserRepository sysUserRepository,
                             QuestionRepository questionRepository,
                             AgentOrchestrator orchestrator,
                             SparkClient sparkClient) {
        this.teacherRepository = teacherRepository;
        this.courseRepository = courseRepository;
        this.chapterRepository = chapterRepository;
        this.progressRepository = progressRepository;
        this.sysUserRepository = sysUserRepository;
        this.questionRepository = questionRepository;
        this.orchestrator = orchestrator;
        this.sparkClient = sparkClient;
    }

    // ===== 教师信息 =====

    @GetMapping("/{id}")
    public Result<Teacher> getProfile(@PathVariable Long id) {
        return teacherRepository.findById(id)
                .map(Result::success)
                .orElse(Result.error(404, "教师不存在"));
    }

    @GetMapping("/{id}/info")
    public Result<Map<String, Object>> getInfo(@PathVariable Long id) {
        return sysUserRepository.findById(id).map(u -> {
            Map<String, Object> map = new LinkedHashMap<>();
            map.put("nickname", u.getNickname());
            map.put("phone", u.getPhone());
            map.put("username", u.getUsername());
            return Result.success(map);
        }).orElse(Result.error(404, "用户不存在"));
    }

    @PostMapping("/{id}/info")
    public Result<SysUser> updateInfo(@PathVariable Long id, @RequestBody Map<String, String> body) {
        return sysUserRepository.findById(id).map(u -> {
            if (body.containsKey("nickname")) u.setNickname(body.get("nickname"));
            if (body.containsKey("phone")) u.setPhone(body.get("phone"));
            return Result.success(sysUserRepository.save(u));
        }).orElse(Result.error(404, "用户不存在"));
    }

    @PostMapping("/{id}/password")
    public Result<?> changePassword(@PathVariable Long id, @RequestBody Map<String, String> body) {
        return sysUserRepository.findById(id).map(u -> {
            String oldPwd = body.get("oldPassword");
            String newPwd = body.get("newPassword");
            if (!u.getPassword().equals(oldPwd)) return Result.error(400, "原密码错误");
            u.setPassword(newPwd);
            sysUserRepository.save(u);
            return Result.success("修改成功");
        }).orElse(Result.error(404, "用户不存在"));
    }

    @PostMapping("/register")
    public Result<Teacher> register(@RequestBody Map<String, String> body) {
        Teacher teacher = new Teacher();
        teacher.setUsername(body.get("username"));
        teacher.setNickname(body.getOrDefault("nickname", body.get("username")));
        teacher.setDepartment(body.getOrDefault("department", "计算机学院"));
        teacher.setCourse(body.getOrDefault("course", "C语言程序设计"));
        return Result.success(teacherRepository.save(teacher));
    }

    // ===== 课程管理 =====

    @GetMapping("/{teacherId}/courses")
    public Result<List<Course>> getCourses(@PathVariable Long teacherId) {
        return Result.success(courseRepository.findByTeacherId(teacherId));
    }

    @PostMapping("/course")
    public Result<Course> createCourse(@RequestBody Map<String, String> body) {
        Course course = new Course();
        course.setName(body.get("name"));
        course.setCode(body.getOrDefault("code", ""));
        course.setClassName(body.getOrDefault("className", ""));
        course.setTeacherId(Long.valueOf(body.getOrDefault("teacherId", "1")));
        course.setSemester(body.getOrDefault("semester", "2025-2026-2"));
        course.setDescription(body.getOrDefault("description", ""));
        return Result.success(courseRepository.save(course));
    }

    @DeleteMapping("/course/{id}")
    public Result<?> deleteCourse(@PathVariable Long id) {
        Course course = courseRepository.findById(id).orElse(null);
        if (course == null) return Result.error(404, "课程不存在");
        // 删除课程下的所有章节
        List<Chapter> chapters = chapterRepository.findByCourseIdOrderByOrderNum(id);
        chapterRepository.deleteAll(chapters);
        // 删除课程关联的进度记录
        for (Chapter ch : chapters) {
            List<ChapterProgress> progresses = progressRepository.findByChapterId(ch.getId());
            progressRepository.deleteAll(progresses);
        }
        courseRepository.delete(course);
        return Result.success("课程及其章节已删除");
    }

    // ===== 关卡管理（布置作业）=====

    @GetMapping("/{teacherId}/chapters")
    public Result<List<Chapter>> getChapters(@PathVariable Long teacherId) {
        return Result.success(chapterRepository.findByTeacherIdOrderByOrderNum(teacherId));
    }

    @GetMapping("/course/{courseId}/chapters")
    public Result<List<Chapter>> getCourseChapters(@PathVariable Long courseId) {
        return Result.success(chapterRepository.findByCourseIdOrderByOrderNum(courseId));
    }

    /**
     * 创建/更新关卡（含题目）
     * body: { courseId, name, description, orderNum, questions(JSON) }
     * questions格式: [{"type":"choice","content":"题目","options":[{"key":"A","value":"..."}],"answer":"A"},...]
     */
    @PostMapping("/chapter")
    public Result<Chapter> saveChapter(@RequestBody Map<String, Object> body) {
        Long id = body.containsKey("id") ? Long.valueOf(body.get("id").toString()) : null;
        Chapter chapter = id != null ? chapterRepository.findById(id).orElse(new Chapter()) : new Chapter();
        if (body.containsKey("courseId")) chapter.setCourseId(Long.valueOf(body.get("courseId").toString()));
        if (body.containsKey("teacherId")) chapter.setTeacherId(Long.valueOf(body.get("teacherId").toString()));
        if (body.containsKey("name")) chapter.setName(body.get("name").toString());
        if (body.containsKey("description")) chapter.setDescription(body.get("description").toString());
        if (body.containsKey("orderNum")) chapter.setOrderNum(Integer.valueOf(body.get("orderNum").toString()));
        if (body.containsKey("questions")) chapter.setQuestions(body.get("questions").toString());
        chapter.setStatus("draft");
        return Result.success(chapterRepository.save(chapter));
    }

    /**
     * 发布关卡 → 学生可见可答
     */
    @PostMapping("/chapter/{id}/publish")
    public Result<Chapter> publishChapter(@PathVariable Long id) {
        return chapterRepository.findById(id).map(ch -> {
            ch.setStatus("published");
            ch.setPublishedAt(LocalDateTime.now());
            return Result.success(chapterRepository.save(ch));
        }).orElse(Result.error(404, "关卡不存在"));
    }

    /**
     * 取消发布 → 学生不可见
     */
    @PostMapping("/chapter/{id}/unpublish")
    public Result<Chapter> unpublishChapter(@PathVariable Long id) {
        return chapterRepository.findById(id).map(ch -> {
            ch.setStatus("draft");
            return Result.success(chapterRepository.save(ch));
        }).orElse(Result.error(404, "关卡不存在"));
    }

    @DeleteMapping("/chapter/{id}")
    public Result<?> deleteChapter(@PathVariable Long id) {
        chapterRepository.deleteById(id);
        return Result.success("删除成功");
    }

    /**
     * 布置作业 - 教师点击布置按钮后，为课程班级的所有学生创建作业记录
     */
    @PostMapping("/chapter/{chapterId}/assign")
    public Result<Map<String, Object>> assignChapter(@PathVariable Long chapterId, 
                                                      @RequestBody Map<String, Object> body) {
        // 获取章节信息
        Chapter chapter = chapterRepository.findById(chapterId).orElse(null);
        if (chapter == null) return Result.error(404, "关卡不存在");
        if (!"published".equals(chapter.getStatus())) return Result.error(400, "关卡未发布，无法布置");

        Long teacherId = body.containsKey("teacherId") ? Long.valueOf(body.get("teacherId").toString()) : null;
        Long courseId = body.containsKey("courseId") ? Long.valueOf(body.get("courseId").toString()) : null;

        // 获取课程信息
        Course course = courseRepository.findById(courseId).orElse(null);
        if (course == null) return Result.error(404, "课程不存在");

        // 获取该课程班级的所有学生
        String className = course.getClassName();
        List<SysUser> students = sysUserRepository.findByClassName(className);
        int assignedCount = 0;

        // 为每个学生创建或更新进度记录
        for (SysUser student : students) {
            if (!"student".equals(student.getRole())) continue;

            Long studentId = student.getId();
            // 检查是否已有进度记录
            ChapterProgress existingProgress = progressRepository
                    .findByChapterIdAndStudentId(chapterId, studentId).orElse(null);

            if (existingProgress == null) {
                // 创建新进度记录
                ChapterProgress progress = new ChapterProgress();
                progress.setChapterId(chapterId);
                progress.setStudentId(studentId);
                progress.setStatus("pending");
                progress.setScore(null);
                progress.setAnswers(null);
                progressRepository.save(progress);
                assignedCount++;
            } else if ("completed".equals(existingProgress.getStatus())) {
                // 如果已完成，重置为待完成状态（允许重新布置）
                existingProgress.setStatus("pending");
                existingProgress.setScore(null);
                existingProgress.setAnswers(null);
                progressRepository.save(existingProgress);
                assignedCount++;
            }
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("chapterId", chapterId);
        result.put("chapterName", chapter.getName());
        result.put("assignedCount", assignedCount);
        result.put("message", "作业已布置给 " + assignedCount + " 名学生");
        return Result.success(result);
    }

    // ===== 作业批改（AI智能体）=====

    /**
     * 获取某关卡的所有学生提交
     */
    @GetMapping("/chapter/{chapterId}/submissions")
    public Result<List<Map<String, Object>>> getChapterSubmissions(@PathVariable Long chapterId) {
        List<ChapterProgress> progresses = progressRepository.findByChapterId(chapterId);
        List<Map<String, Object>> result = new ArrayList<>();
        for (ChapterProgress cp : progresses) {
            Map<String, Object> item = new LinkedHashMap<>();
            item.put("progressId", cp.getId());
            item.put("studentId", cp.getStudentId());
            sysUserRepository.findById(cp.getStudentId()).ifPresent(u -> {
                item.put("nickname", u.getNickname());
                item.put("username", u.getUsername());
            });
            item.put("score", cp.getScore());
            item.put("status", cp.getStatus());
            item.put("answers", cp.getAnswers());
            item.put("feedback", cp.getFeedback());
            item.put("submittedAt", cp.getSubmittedAt());
            item.put("gradedAt", cp.getGradedAt());
            result.add(item);
        }
        return Result.success(result);
    }

    /**
     * AI批改单个提交 — 使用星火大模型综合评阅
     */
    @PostMapping("/submission/{progressId}/ai-grade")
    public Result<Map<String, Object>> aiGradeSubmission(@PathVariable Long progressId) {
        return progressRepository.findById(progressId).map(cp -> {
            Optional<Chapter> chapterOpt = chapterRepository.findById(cp.getChapterId());
            if (chapterOpt.isEmpty()) return (Result) Result.error(404, "关卡不存在");
            Chapter chapter = chapterOpt.get();
            String questionsJson = chapter.getQuestions();
            String answersJson = cp.getAnswers();
            if (questionsJson == null || answersJson == null) {
                return (Result) Result.error(400, "题目或答案为空");
            }
            try {
                JSONArray questions = JSON.parseArray(questionsJson);
                JSONObject studentAnswers = JSON.parseObject(answersJson);
                int total = questions.size();
                int correct = 0;
                StringBuilder feedback = new StringBuilder();

                for (int i = 0; i < total; i++) {
                    JSONObject q = questions.getJSONObject(i);
                    String qId = String.valueOf(i + 1);
                    String type = q.getString("type");
                    String correctAnswer = q.getString("answer");
                    String studentAnswer = studentAnswers.getString(qId);
                    String questionContent = q.getString("content");

                    if ("choice".equals(type)) {
                        // 选择题：精确匹配
                        if (correctAnswer != null && correctAnswer.equalsIgnoreCase(
                                studentAnswer != null ? studentAnswer.trim() : "")) {
                            correct++;
                            feedback.append("✓第").append(i + 1).append("题 ");
                        } else {
                            feedback.append("✗第").append(i + 1).append("题(正确答案:").append(correctAnswer).append(") ");
                        }
                    } else if ("code".equals(type)) {
                        // 代码题：AI评阅
                        if (studentAnswer != null && studentAnswer.length() >= 10) {
                            String aiFeedback = sparkClient.chat(
                                "你是C语言代码评阅老师。请判断学生代码是否正确实现了题目要求。\n"
                                + "题目：" + questionContent + "\n"
                                + "参考答案：\n" + correctAnswer + "\n"
                                + "学生代码：\n" + studentAnswer + "\n"
                                + "如果正确回复'通过'，否则指出问题。50字以内。",
                                studentAnswer, 0.3f, 150
                            );
                            boolean passed = aiFeedback.contains("通过") || aiFeedback.contains("正确");
                            if (passed) { correct++; }
                            feedback.append(passed ? "✓" : "✗").append("第").append(i + 1).append("题(代码) ");
                            feedback.append(aiFeedback.trim()).append(" ");
                        } else {
                            feedback.append("✗第").append(i + 1).append("题(未作答) ");
                        }
                    } else {
                        // 填空题/主观题：AI语义评阅
                        if (studentAnswer != null && !studentAnswer.trim().isEmpty()) {
                            String aiFeedback = sparkClient.chat(
                                "你是C语言教学评阅老师。请判断学生答案是否与正确答案语义一致。\n"
                                + "题目：" + questionContent + "\n"
                                + "正确答案：" + correctAnswer + "\n"
                                + "学生答案：" + studentAnswer + "\n"
                                + "如果语义正确回复'通过'，否则回复'不通过'。30字以内。",
                                studentAnswer, 0.3f, 100
                            );
                            boolean passed = aiFeedback.contains("通过") || aiFeedback.contains("正确");
                            if (passed) { correct++; }
                            feedback.append(passed ? "✓" : "✗").append("第").append(i + 1).append("题 ");
                            feedback.append(aiFeedback.trim()).append(" ");
                        } else {
                            feedback.append("✗第").append(i + 1).append("题(未作答) ");
                        }
                    }
                }

                int score = (int) Math.round((double) correct / total * 100);
                cp.setScore(score);
                cp.setFeedback(feedback.toString());
                cp.setStatus("completed");
                cp.setGradedBy("ai");
                cp.setGradedAt(LocalDateTime.now());
                progressRepository.save(cp);

                Map<String, Object> result = new LinkedHashMap<>();
                result.put("score", score);
                result.put("feedback", feedback.toString());
                result.put("correctCount", correct);
                result.put("totalCount", total);
                return Result.success(result);
            } catch (Exception e) {
                log.error("AI批改失败", e);
                return (Result) Result.error(500, "批改失败：" + e.getMessage());
            }
        }).orElse((Result) Result.error(404, "提交不存在"));
    }

    /**
     * 教师手动批改/覆盖AI结果
     */
    @PostMapping("/submission/{progressId}/manual-grade")
    public Result<ChapterProgress> manualGrade(@PathVariable Long progressId, @RequestBody Map<String, Object> body) {
        return progressRepository.findById(progressId).map(cp -> {
            if (body.containsKey("score")) cp.setScore((Integer) body.get("score"));
            if (body.containsKey("feedback")) cp.setFeedback(body.get("feedback").toString());
            cp.setGradedBy("teacher");
            cp.setGradedAt(LocalDateTime.now());
            return Result.success(progressRepository.save(cp));
        }).orElse(Result.error(404, "提交不存在"));
    }

    // ===== 学情分析（AI智能体）=====

    /**
     * AI班级学情分析
     * 返回：班级整体正确率、各题正确率、薄弱知识点、建议
     */
    @GetMapping("/class/{className}/ai-analysis")
    public Result<Map<String, Object>> getClassAiAnalysis(@PathVariable String className) {
        try {
            // 获取班级所有学生
            List<SysUser> users = sysUserRepository.findByClassName(className);
            List<Long> studentIds = new ArrayList<>();
            for (SysUser u : users) {
                if ("student".equals(u.getRole())) studentIds.add(u.getId());
            }
            if (studentIds.isEmpty()) return Result.success(Collections.emptyMap());

            // 获取所有相关关卡的进度
            List<Chapter> publishedChapters = chapterRepository.findByStatusOrderByOrderNum("published");
            List<Long> chapterIds = new ArrayList<>();
            for (Chapter ch : publishedChapters) chapterIds.add(ch.getId());
            if (chapterIds.isEmpty()) return Result.success(Collections.emptyMap());

            List<ChapterProgress> allProgress = progressRepository.findByChapterIdIn(chapterIds);
            // 只保留本班学生的进度
            List<ChapterProgress> classProgress = new ArrayList<>();
            Set<Long> studentIdSet = new HashSet<>(studentIds);
            for (ChapterProgress cp : allProgress) {
                if (studentIdSet.contains(cp.getStudentId())) classProgress.add(cp);
            }

            // 统计
            int totalSubmissions = classProgress.size();
            int totalScore = 0;
            int gradedCount = 0;
            for (ChapterProgress cp : classProgress) {
                if (cp.getScore() != null) {
                    totalScore += cp.getScore();
                    gradedCount++;
                }
            }
            double avgScore = gradedCount > 0 ? (double) totalScore / gradedCount : 0;

            Map<String, Object> result = new LinkedHashMap<>();
            result.put("totalStudents", studentIds.size());
            result.put("totalSubmissions", totalSubmissions);
            result.put("averageScore", Math.round(avgScore * 100.0) / 100.0);
            result.put("publishedChapters", publishedChapters.size());

            // AI分析（调用大模型）
            StringBuilder aiPrompt = new StringBuilder();
            aiPrompt.append("你是一位教学分析师。请根据以下班级数据，给出学情分析：\n");
            aiPrompt.append("班级：").append(className).append("\n");
            aiPrompt.append("学生人数：").append(studentIds.size()).append("\n");
            aiPrompt.append("已提交次数：").append(totalSubmissions).append("\n");
            aiPrompt.append("平均分：").append(Math.round(avgScore * 100.0) / 100.0).append("\n");
            aiPrompt.append("请分析班级整体学习情况，指出薄弱知识点，给出教学建议。用中文回答，不超过300字。");
            try {
                // 简单调用AI（使用ChatController类似的方式）
                // 这里复用AgentOrchestrator的AI能力
                com.happymouse.cryd.model.dto.ChatRequest req = new com.happymouse.cryd.model.dto.ChatRequest();
                req.setStudentId(studentIds.isEmpty() ? 1L : studentIds.get(0));
                req.setMessage(aiPrompt.toString());
                com.happymouse.cryd.model.dto.ChatResponse aiResp = orchestrator.process(req);
                result.put("aiAnalysis", aiResp != null ? aiResp.getMessage() : "暂无AI分析");
            } catch (Exception e) {
                log.warn("AI分析失败", e);
                result.put("aiAnalysis", "AI分析暂时不可用");
            }
            return Result.success(result);
        } catch (Exception e) {
            log.error("班级分析失败", e);
            return Result.error(500, "分析失败：" + e.getMessage());
        }
    }

    // ===== AI智能出题 =====

    private static final String QUESTION_GEN_PROMPT = """
        你是C语言程序设计出题专家。请根据给定的章节信息，生成4道选择题和1道代码题。

        必须严格遵守以下要求：
        1. 选择题：4个选项(A/B/C/D)，每个选项有意义且有且仅有一个正确答案
        2. 代码题：有明确的输入输出要求，参考答案是完整可运行的C代码
        3. 每题必须标注知识点(knowledgePoint)和解析(analysis)
        4. 题目难度适中，适合大学本科生水平
        5. 选择题的options必须是包含key和value的对象数组

        必须输出纯JSON数组格式（不要```json标记，不要其他任何文字），格式如下：
        [{"type":"choice","content":"题目","options":[{"key":"A","value":"选项A"},{"key":"B","value":"选项B"},{"key":"C","value":"选项C"},{"key":"D","value":"选项D"}],"answer":"A","knowledgePoint":"知识点","analysis":"解析"}]
        """;

    /**
     * AI生成题目 — 最多重试2次，JSON多策略容错
     */
    @PostMapping("/chapter/{chapterId}/ai-generate-questions")
    public Result<Map<String, Object>> aiGenerateQuestions(@PathVariable Long chapterId,
                                                            @RequestBody Map<String, Object> body) {
        return chapterRepository.findById(chapterId).map(ch -> {
            String chapterName = ch.getName();
            String chapterDesc = ch.getDescription() != null ? ch.getDescription() : "";

            String prompt = QUESTION_GEN_PROMPT
                    + "\n\n章节名称：" + chapterName
                    + "\n章节描述：" + chapterDesc
                    + "\n\n请严格按照上述JSON格式生成题目。";

            JSONArray questions = null;
            int maxRetries = 2;
            for (int attempt = 0; attempt <= maxRetries && (questions == null || questions.isEmpty()); attempt++) {
                if (attempt > 0) {
                    log.warn("AI出题第{}次重试: chapter={}", attempt, chapterName);
                    prompt = prompt + "\n\n【重要提醒】第" + attempt + "次重试，上次输出格式不符合JSON规范，请这次一定只输出纯JSON数组。";
                }
                questions = tryGenerateQuestions(prompt, chapterName);
            }

            if (questions == null || questions.isEmpty()) {
                log.error("AI出题全部{}次尝试均失败: chapter={}", maxRetries + 1, chapterName);
                return Result.<Map<String, Object>>error(500, "AI生成题目失败，已重试" + maxRetries + "次仍无法解析有效题目。请检查关卡名称和描述是否清晰，或手动录入题目。");
            }

            // 校验题目数量，补全不足的
            int choiceCount = 0;
            int codeCount = 0;
            for (int i = 0; i < questions.size(); i++) {
                JSONObject q = questions.getJSONObject(i);
                String type = q.getString("type");
                if ("choice".equals(type)) choiceCount++;
                else if ("code".equals(type)) codeCount++;
            }
            if (choiceCount < 4 || codeCount < 1) {
                log.info("AI生成题目数量不足(choice={}, code={})，已生成题目将继续使用", choiceCount, codeCount);
            }

            // 保存到章节
            ch.setQuestions(questions.toJSONString());
            chapterRepository.save(ch);

            Map<String, Object> result = new LinkedHashMap<>();
            result.put("chapterId", chapterId);
            result.put("questionCount", questions.size());
            result.put("choiceCount", choiceCount);
            result.put("codeCount", codeCount);
            result.put("questions", questions);
            result.put("message", "AI已生成 " + questions.size() + " 道题目（" + choiceCount + "选择+" + codeCount + "代码）");
            return Result.success(result);
        }).orElse(Result.<Map<String, Object>>error(404, "关卡不存在"));
    }

    /**
     * 尝试调用AI生成题目并解析JSON，失败返回null
     */
    private JSONArray tryGenerateQuestions(String prompt, String chapterName) {
        try {
            String aiReply = sparkClient.chat(prompt, "出题-" + chapterName, 0.3f, 2048);
            log.info("AI生成题目原始回复(前200字符): {}",
                    aiReply != null ? aiReply.substring(0, Math.min(200, aiReply.length())) : "null");

            if (aiReply == null || aiReply.trim().isEmpty()) {
                log.warn("AI返回空内容");
                return null;
            }

            String jsonStr = extractJsonArray(aiReply);
            if (jsonStr == null) {
                log.warn("无法从AI回复中提取JSON数组");
                return null;
            }

            JSONArray questions = JSON.parseArray(jsonStr);
            return questions;
        } catch (Exception e) {
            log.error("AI生成题目异常: {}", e.getMessage());
            return null;
        }
    }

    /**
     * 从AI回复中提取JSON数组（多策略容错，适配 LLM 输出特性）
     */
    private String extractJsonArray(String raw) {
        String text = raw.trim();

        // 策略1: 去掉markdown标记后提取
        String cleaned = text.replaceAll("```json\\s*", "").replaceAll("```\\s*", "");
        int start = cleaned.indexOf('[');
        int end = cleaned.lastIndexOf(']');
        if (start >= 0 && end > start) {
            String candidate = cleaned.substring(start, end + 1);
            if (isValidJsonArray(candidate)) return candidate;
        }

        // 策略2: 修复常见JSON格式问题 + LLM常见输出修复
        start = text.indexOf('[');
        end = text.lastIndexOf(']');
        if (start >= 0 && end > start) {
            String candidate = text.substring(start, end + 1);
            candidate = candidate.replaceAll("```json\\s*", "").replaceAll("```\\s*", "");
            // 尾逗号修复
            candidate = candidate.replaceAll(",\\s*]", "]");
            candidate = candidate.replaceAll(",\\s*}", "}");
            // LLM 常见: 字符串值中含未转义换行
            candidate = candidate.replace("\r\n", "\\n").replace("\r", "\\n").replace("\n", "\\n");
            if (isValidJsonArray(candidate)) return candidate;
            // LLM 常见: 中文引号混入
            candidate = candidate.replace("“", "\"").replace("”", "\"");
            candidate = candidate.replace('‘', '\'').replace('’', '\'');
            if (isValidJsonArray(candidate)) return candidate;
        }

        // 策略3: 修复缺失的逗号（LLM有时在数组元素间漏掉逗号）
        start = text.indexOf('[');
        end = text.lastIndexOf(']');
        if (start >= 0 && end > start) {
            String candidate = text.substring(start, end + 1);
            candidate = candidate.replaceAll("```json\\s*", "").replaceAll("```\\s*", "");
            candidate = candidate.replaceAll("}\\s*\\{", "},{");
            candidate = candidate.replaceAll(",\\s*]", "]");
            candidate = candidate.replaceAll(",\\s*}", "}");
            if (isValidJsonArray(candidate)) return candidate;
        }

        // 策略4: 逐个提取JSON对象组装
        try {
            List<String> objects = new ArrayList<>();
            int depth = 0;
            StringBuilder current = new StringBuilder();
            boolean inString = false;
            for (int i = 0; i < text.length(); i++) {
                char ch = text.charAt(i);
                if (ch == '"' && (i == 0 || text.charAt(i - 1) != '\\')) inString = !inString;
                if (!inString) {
                    if (ch == '{') {
                        if (depth == 0) current = new StringBuilder();
                        depth++;
                    }
                    if (depth > 0) current.append(ch);
                    if (ch == '}') {
                        depth--;
                        if (depth == 0) {
                            objects.add(current.toString());
                        }
                    }
                } else if (depth > 0) {
                    current.append(ch);
                }
            }
            if (!objects.isEmpty()) {
                return "[" + String.join(",", objects) + "]";
            }
        } catch (Exception ignored) {}

        return null;
    }

    private boolean isValidJsonArray(String str) {
        try {
            JSON.parseArray(str);
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    // ===== 直接AI出题（不需要预先创建关卡）=====

    private static final String DIRECT_QUESTION_PROMPT = """
        你是C语言程序设计出题专家。请根据给定的知识点/章节名称，生成4道选择题和1道代码题。

        必须严格遵守以下要求：
        1. 选择题：4个选项(A/B/C/D)，每个选项有意义且有且仅有一个正确答案
        2. 代码题：有明确的输入输出要求，参考答案是完整可运行的C代码
        3. 每题必须标注知识点(knowledgePoint)和解析(analysis)
        4. 题目难度适中，适合大学本科生水平
        5. 选择题的options必须是包含key和value的对象数组

        必须输出纯JSON数组格式（不要```json标记，不要其他任何文字），格式如下：
        [{"type":"choice","content":"题目","options":[{"key":"A","value":"选项A"},{"key":"B","value":"选项B"},{"key":"C","value":"选项C"},{"key":"D","value":"选项D"}],"answer":"A","knowledgePoint":"知识点","analysis":"解析"},
         {"type":"code","content":"题目描述（含输入输出要求）","answer":"参考答案C代码","knowledgePoint":"知识点","analysis":"解题思路和考点分析"}]
        """;

    /**
     * 直接AI出题 — 只需要输入知识点名称，星火大模型直接生成题目
     * 适用于快速出题，不需要预先创建关卡
     */
    @PostMapping("/direct-generate-questions")
    public Result<Map<String, Object>> directGenerateQuestions(@RequestBody Map<String, Object> body) {
        String topic = (String) body.getOrDefault("topic", "C语言基础");
        int questionCount = (int) body.getOrDefault("questionCount", 5);
        String difficulty = (String) body.getOrDefault("difficulty", "中等");

        String prompt = DIRECT_QUESTION_PROMPT
                + "\n\n知识点/章节名称：" + topic
                + "\n难度要求：" + difficulty
                + "\n需要生成题目数量：" + questionCount + "道（含至少1道代码题）"
                + "\n\n请严格按照上述JSON格式生成题目。";

        JSONArray questions = tryGenerateQuestions(prompt, topic);

        if (questions == null || questions.isEmpty()) {
            log.warn("直接AI出题首次失败，重试中...");
            String retryPrompt = prompt + "\n\n【重要】上一次输出不是合法的JSON数组。这次务必只输出纯JSON数组，不要任何其他文字。";
            questions = tryGenerateQuestions(retryPrompt, topic);
        }

        if (questions == null || questions.isEmpty()) {
            return Result.error(500, "星火大模型出题失败，已重试仍无法生成有效题目。请尝试更换知识点描述后重试。");
        }

        int choiceCount = 0, codeCount = 0, fillCount = 0;
        for (int i = 0; i < questions.size(); i++) {
            JSONObject q = questions.getJSONObject(i);
            String type = q.getString("type");
            if ("choice".equals(type)) choiceCount++;
            else if ("code".equals(type)) codeCount++;
            else fillCount++;
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("topic", topic);
        result.put("difficulty", difficulty);
        result.put("questionCount", questions.size());
        result.put("choiceCount", choiceCount);
        result.put("codeCount", codeCount);
        result.put("fillCount", fillCount);
        result.put("questions", questions);
        result.put("message", "星火大模型已生成 " + questions.size() + " 道题目（"
                + choiceCount + "选择 + " + codeCount + "代码" +
                (fillCount > 0 ? " + " + fillCount + "填空" : "") + "）");
        return Result.success(result);
    }

    // ===== 课本目录 + 一键布置 =====

    /**
     * 获取课本目录 — 所有已发布章节（从数据库）或从题库JSON加载
     */
    @GetMapping("/textbook-contents")
    public Result<List<Map<String, Object>>> getTextbookContents() {
        // 先从数据库获取已发布章节
        List<Chapter> publishedChapters = chapterRepository.findByStatusOrderByOrderNum("published");
        // 同时从题库JSON读取完整目录（确保10章都有）
        List<Map<String, Object>> toc = new ArrayList<>();
        try {
            org.springframework.core.io.Resource jsonResource =
                    new org.springframework.core.io.ClassPathResource("question-bank/c-programming.json");
            if (jsonResource.exists()) {
                String jsonStr = new String(jsonResource.getInputStream().readAllBytes(), java.nio.charset.StandardCharsets.UTF_8);
                JSONArray chapters = JSON.parseArray(jsonStr);
                Set<Long> publishedIds = new HashSet<>();
                for (Chapter ch : publishedChapters) publishedIds.add(ch.getId());

                for (int i = 0; i < chapters.size(); i++) {
                    JSONObject chJson = chapters.getJSONObject(i);
                    Map<String, Object> item = new LinkedHashMap<>();
                    item.put("orderNum", chJson.getInteger("orderNum"));
                    item.put("name", chJson.getString("name"));
                    item.put("description", chJson.getString("description"));
                    item.put("questionCount", chJson.getJSONArray("questions").size());
                    // 查找是否已有对应的数据库章节
                    Chapter existing = publishedChapters.stream()
                            .filter(c -> c.getName().equals(chJson.getString("name")))
                            .findFirst().orElse(null);
                    item.put("chapterId", existing != null ? existing.getId() : null);
                    item.put("assigned", existing != null && "published".equals(existing.getStatus()));
                    item.put("status", existing != null ? existing.getStatus() : "not_created");
                    toc.add(item);
                }
                return Result.success(toc);
            }
        } catch (Exception e) {
            log.warn("读取题库JSON失败，回退到数据库: {}", e.getMessage());
        }
        // JSON读取失败，回退到数据库
        for (Chapter ch : publishedChapters) {
            Map<String, Object> item = new LinkedHashMap<>();
            item.put("orderNum", ch.getOrderNum());
            item.put("name", ch.getName());
            item.put("description", ch.getDescription());
            item.put("questionCount", ch.getQuestions() != null ? getQuestionCount(ch.getQuestions()) : 0);
            item.put("chapterId", ch.getId());
            item.put("assigned", true);
            item.put("status", ch.getStatus());
            toc.add(item);
        }
        return Result.success(toc);
    }

    /**
     * 一键批量布置 — 勾选章节后自动AI出题+发布+布置给全班
     */
    @PostMapping("/batch-assign")
    public Result<Map<String, Object>> batchAssign(@RequestBody Map<String, Object> body) {
        Long teacherId = Long.valueOf(body.get("teacherId").toString());
        Long courseId = Long.valueOf(body.get("courseId").toString());
        @SuppressWarnings("unchecked")
        List<String> chapterNames = (List<String>) body.getOrDefault("chapterNames", Collections.emptyList());
        boolean useAiGenerate = (boolean) body.getOrDefault("useAiGenerate", true);

        if (chapterNames.isEmpty()) return Result.error(400, "请至少选择一个章节");

        Course course = courseRepository.findById(courseId).orElse(null);
        if (course == null) return Result.error(404, "课程不存在");

        String className = course.getClassName();
        List<SysUser> students = sysUserRepository.findByClassName(className).stream()
                .filter(u -> "student".equals(u.getRole())).toList();
        if (students.isEmpty()) return Result.error(400, "该班级暂无学生，请先让学生注册到班级 " + className);

        int assignedCount = 0;
        int totalQuestions = 0;
        List<String> assignedChapters = new ArrayList<>();

        for (String chapterName : chapterNames) {
            // 查找或创建章节
            List<Chapter> existingChapters = chapterRepository.findByStatusOrderByOrderNum("published");
            Chapter chapter = existingChapters.stream()
                    .filter(c -> c.getName().equals(chapterName)).findFirst()
                    .orElseGet(() -> {
                        Chapter newCh = new Chapter();
                        newCh.setName(chapterName);
                        newCh.setCourseId(courseId);
                        newCh.setTeacherId(teacherId);
                        newCh.setOrderNum(chapterNames.indexOf(chapterName) + 1);
                        newCh.setDescription(chapterName);
                        newCh.setStatus("draft");
                        return chapterRepository.save(newCh);
                    });

            // AI出题（如果启用且章节没题目）
            if (useAiGenerate && (chapter.getQuestions() == null || getQuestionCount(chapter.getQuestions()) == 0)) {
                String prompt = QUESTION_GEN_PROMPT + "\n\n章节名称：" + chapterName
                        + "\n\n请严格按照JSON格式生成题目。";
                JSONArray questions = tryGenerateQuestions(prompt, chapterName);
                if (questions != null && !questions.isEmpty()) {
                    chapter.setQuestions(questions.toJSONString());
                }
            }

            // 发布
            chapter.setStatus("published");
            chapter.setPublishedAt(LocalDateTime.now());
            chapterRepository.save(chapter);

            // 布置给全班学生
            for (SysUser student : students) {
                ChapterProgress existingProgress = progressRepository
                        .findByChapterIdAndStudentId(chapter.getId(), student.getId()).orElse(null);
                if (existingProgress == null) {
                    ChapterProgress progress = new ChapterProgress();
                    progress.setChapterId(chapter.getId());
                    progress.setStudentId(student.getId());
                    progress.setStatus("pending");
                    progressRepository.save(progress);
                    assignedCount++;
                }
            }

            int qCount = chapter.getQuestions() != null ? getQuestionCount(chapter.getQuestions()) : 0;
            totalQuestions += qCount;
            assignedChapters.add(chapterName + "(" + qCount + "题)");
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("assignedChapters", assignedChapters);
        result.put("chapterCount", chapterNames.size());
        result.put("totalQuestions", totalQuestions);
        result.put("studentCount", students.size());
        result.put("assignedCount", assignedCount);
        result.put("message", "成功布置 " + chapterNames.size() + " 章，共 " + totalQuestions + " 题，分发给 " + students.size() + " 名学生");
        return Result.success(result);
    }

    // ===== 扩展题库 =====

    /**
     * 一键扩展题库 — 为所有章节自动补充题目到至少10题/章
     */
    @PostMapping("/expand-question-bank")
    public Result<Map<String, Object>> expandQuestionBank() {
        List<Chapter> allChapters = chapterRepository.findByStatusOrderByOrderNum("published");
        // 也包括草稿
        allChapters.addAll(chapterRepository.findAll().stream()
                .filter(c -> !"published".equals(c.getStatus())).toList());

        int expandedCount = 0;
        int totalNewQuestions = 0;
        List<String> expandedChapters = new ArrayList<>();

        for (Chapter ch : allChapters) {
            int currentCount = ch.getQuestions() != null ? getQuestionCount(ch.getQuestions()) : 0;
            if (currentCount >= 10) continue; // 已有足够题目

            int needCount = 10 - currentCount;
            log.info("扩展题库章节「{}」: 当前{}题, 需补充{}题", ch.getName(), currentCount, needCount);

            try {
                String prompt = QUESTION_GEN_PROMPT
                        + "\n\n章节名称：" + ch.getName()
                        + "\n已有题目数：" + currentCount
                        + "\n需要补充：" + needCount + "道新题（不要与已有题目重复）"
                        + "\n\n请严格按照JSON格式生成。";

                JSONArray newQuestions = tryGenerateQuestions(prompt, ch.getName());
                if (newQuestions != null && !newQuestions.isEmpty()) {
                    // 合并题目
                    JSONArray allQuestions = new JSONArray();
                    if (ch.getQuestions() != null) {
                        try {
                            JSONArray existing = JSON.parseArray(ch.getQuestions());
                            allQuestions.addAll(existing);
                        } catch (Exception ignored) {}
                    }
                    allQuestions.addAll(newQuestions);
                    ch.setQuestions(allQuestions.toJSONString());
                    chapterRepository.save(ch);
                    expandedCount++;
                    totalNewQuestions += newQuestions.size();
                    expandedChapters.add(ch.getName() + "(+" + newQuestions.size() + "题)");
                    log.info("章节「{}」题库扩展完成: +{}题, 共{}题", ch.getName(), newQuestions.size(), allQuestions.size());
                }
            } catch (Exception e) {
                log.warn("扩展章节「{}」失败: {}", ch.getName(), e.getMessage());
            }
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("expandedCount", expandedCount);
        result.put("totalNewQuestions", totalNewQuestions);
        result.put("expandedChapters", expandedChapters);
        result.put("message", "题库扩展完成: " + expandedCount + "章, 共新增" + totalNewQuestions + "题");
        return Result.success(result);
    }

    // ===== 题库管理：题目浏览、AI生成、选中布置 =====

    /**
     * 浏览题库 — 按课程/章节/难度/类型筛选
     */
    @GetMapping("/questions")
    public Result<Map<String, Object>> getQuestions(
            @RequestParam(required = false) Long courseId,
            @RequestParam(required = false) String chapterName,
            @RequestParam(required = false) String difficulty,
            @RequestParam(required = false) String type) {
        // 优先从数据库加载题目
        List<Question> filtered = courseId != null
                ? new ArrayList<>(questionRepository.findByCourseIdOrderByChapterOrderAsc(courseId))
                : new ArrayList<>(questionRepository.findAll());

        // 过滤条件
        if (chapterName != null && !chapterName.isEmpty())
            filtered = new ArrayList<>(filtered.stream().filter(q -> chapterName.equals(q.getChapterName())).toList());
        if (difficulty != null && !difficulty.isEmpty())
            filtered = new ArrayList<>(filtered.stream().filter(q -> difficulty.equals(q.getDifficulty())).toList());
        if (type != null && !type.isEmpty())
            filtered = new ArrayList<>(filtered.stream().filter(q -> type.equals(q.getType())).toList());

        // 如果数据库无题，从JSON题库导入
        if (filtered.isEmpty() && courseId != null) {
            List<Question> imported = importQuestionsFromJson(courseId);
            filtered = imported;
            if (chapterName != null && !chapterName.isEmpty())
                filtered = filtered.stream().filter(q -> chapterName.equals(q.getChapterName())).toList();
            if (difficulty != null && !difficulty.isEmpty())
                filtered = filtered.stream().filter(q -> difficulty.equals(q.getDifficulty())).toList();
            if (type != null && !type.isEmpty())
                filtered = filtered.stream().filter(q -> type.equals(q.getType())).toList();
        }

        List<String> chapterNames = getChapterNamesFromJson();
        if (chapterNames.isEmpty() && courseId != null) {
            chapterNames = questionRepository.findDistinctChapterNames(courseId);
        }

        List<String> difficulties = questionRepository.findDistinctDifficulties();
        if (difficulties.isEmpty()) difficulties = List.of("easy", "medium", "hard");

        int choiceCount = (int) filtered.stream().filter(q -> "choice".equals(q.getType())).count();
        int codeCount = (int) filtered.stream().filter(q -> "code".equals(q.getType())).count();

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("questions", filtered);
        result.put("total", filtered.size());
        result.put("choiceCount", choiceCount);
        result.put("codeCount", codeCount);
        result.put("chapterNames", chapterNames);
        result.put("difficulties", difficulties);
        return Result.success(result);
    }

    /**
     * 获取题库章节列表 — 从 c-programming.json 读取完整章节目录
     * 即使题库中还没有题目，也会返回所有章节
     */
    @GetMapping("/questions/chapters")
    public Result<List<Map<String, Object>>> getQuestionChapters() {
        return Result.success(getChapterListFromJson());
    }

    private List<Question> importQuestionsFromJson(Long courseId) {
        List<Question> allQuestions = new ArrayList<>();
        try {
            org.springframework.core.io.Resource jsonResource =
                    new org.springframework.core.io.ClassPathResource("question-bank/c-programming.json");
            if (!jsonResource.exists()) return allQuestions;

            String jsonStr = new String(jsonResource.getInputStream().readAllBytes(),
                    java.nio.charset.StandardCharsets.UTF_8);
            JSONObject root = JSON.parseObject(jsonStr);
            JSONArray chapters = root.getJSONArray("chapters");
            for (int i = 0; i < chapters.size(); i++) {
                JSONObject chJson = chapters.getJSONObject(i);
                String chapterName = chJson.getString("chapterName");
                JSONArray sections = chJson.getJSONArray("sections");
                if (sections == null) continue;
                for (int j = 0; j < sections.size(); j++) {
                    JSONObject sec = sections.getJSONObject(j);
                    JSONArray questions = sec.getJSONArray("questions");
                    if (questions == null) continue;
                    for (int k = 0; k < questions.size(); k++) {
                        JSONObject q = questions.getJSONObject(k);
                        Question question = new Question();
                        // 归一化题型: code_output/program → code
                        String rawType = q.getString("type");
                        String normalizedType = switch (rawType) {
                            case "code_output", "program" -> "code";
                            case "choice", "fill" -> rawType;
                            default -> rawType != null ? rawType : "choice";
                        };
                        question.setType(normalizedType);
                        // JSON字段名: "question" → 实体字段: content
                        question.setContent(q.getString("question"));
                        // JSON字段名: "explanation" → 实体字段: analysis
                        question.setAnalysis(q.getString("explanation"));
                        // JSON options 是 ["A选项","B选项",...] → 转换为 [{key:"A",value:"..."}]
                        if (q.containsKey("options")) {
                            JSONArray rawOptions = q.getJSONArray("options");
                            JSONArray dbOptions = new JSONArray();
                            String[] keys = {"A", "B", "C", "D", "E", "F"};
                            for (int oi = 0; oi < rawOptions.size(); oi++) {
                                JSONObject opt = new JSONObject();
                                opt.put("key", keys[oi]);
                                opt.put("value", rawOptions.getString(oi));
                                dbOptions.add(opt);
                            }
                            question.setOptions(dbOptions.toJSONString());
                        }
                        question.setAnswer(q.getString("answer"));
                        question.setKnowledgePoint(q.getString("knowledgePoint"));
                        question.setDifficulty(q.getString("difficulty") != null
                                ? q.getString("difficulty") : "medium");
                        question.setChapterName(chapterName);
                        question.setChapterOrder(i + 1);
                        question.setCourseId(courseId);
                        question.setSource("json-bank");
                        allQuestions.add(questionRepository.save(question));
                    }
                }
            }
        } catch (Exception e) {
            log.warn("从JSON题库导入题目失败: {}", e.getMessage());
        }
        return allQuestions;
    }

    private List<String> getChapterNamesFromJson() {
        List<String> names = new ArrayList<>();
        List<Map<String, Object>> chapters = getChapterListFromJson();
        for (Map<String, Object> ch : chapters) {
            names.add((String) ch.get("chapterName"));
        }
        return names;
    }

    private List<Map<String, Object>> getChapterListFromJson() {
        List<Map<String, Object>> toc = new ArrayList<>();
        try {
            org.springframework.core.io.Resource jsonResource =
                    new org.springframework.core.io.ClassPathResource("question-bank/c-programming.json");
            if (jsonResource.exists()) {
                String jsonStr = new String(jsonResource.getInputStream().readAllBytes(),
                        java.nio.charset.StandardCharsets.UTF_8);
                JSONObject root = JSON.parseObject(jsonStr);
                JSONArray chapters = root.getJSONArray("chapters");
                for (int i = 0; i < chapters.size(); i++) {
                    JSONObject chJson = chapters.getJSONObject(i);
                    Map<String, Object> item = new LinkedHashMap<>();
                    item.put("chapterId", chJson.getInteger("chapterId"));
                    item.put("chapterName", chJson.getString("chapterName"));
                    JSONArray sections = chJson.getJSONArray("sections");
                    List<String> sectionNames = new ArrayList<>();
                    int questionCount = 0;
                    if (sections != null) {
                        for (int j = 0; j < sections.size(); j++) {
                            JSONObject sec = sections.getJSONObject(j);
                            sectionNames.add(sec.getString("sectionName"));
                            JSONArray qs = sec.getJSONArray("questions");
                            if (qs != null) questionCount += qs.size();
                        }
                    }
                    item.put("sections", sectionNames);
                    item.put("questionCount", questionCount);
                    toc.add(item);
                }
            }
        } catch (Exception e) {
            log.warn("读取题库JSON失败: {}", e.getMessage());
        }
        return toc;
    }

    /**
     * AI 生成题目并存入题库表
     * body: { courseId, chapterName, questionType, difficulty, count }
     * questionType: all / choice / fill / code
     */
    @PostMapping("/questions/ai-generate")
    public Result<Map<String, Object>> aiGenerateQuestions(@RequestBody Map<String, Object> body) {
        Long courseId = Long.valueOf(body.get("courseId").toString());
        String chapterName = (String) body.getOrDefault("chapterName", "C语言基础");
        String questionType = (String) body.getOrDefault("questionType", "all");
        String difficulty = (String) body.getOrDefault("difficulty", "medium");
        int count = (int) body.getOrDefault("count", 5);

        Course course = courseRepository.findById(courseId).orElse(null);

        String typeInstruction;
        switch (questionType) {
            case "choice":
                typeInstruction = "全部生成选择题。选择题格式：{\"type\":\"choice\",\"content\":\"题目\",\"options\":[{\"key\":\"A\",\"value\":\"选项A\"}...],\"answer\":\"A\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解析\"}";
                break;
            case "fill":
                typeInstruction = "全部生成填空题。填空题格式：{\"type\":\"fill\",\"content\":\"题目（用______表示填空处）\",\"answer\":\"答案\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解析\"}";
                break;
            case "code":
                typeInstruction = "全部生成编程题。编程题格式：{\"type\":\"code\",\"content\":\"题目描述（含输入输出要求）\",\"answer\":\"参考答案C代码\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解题思路\"}";
                break;
            default:
                typeInstruction = "混合生成选择题和编程题。选择题格式：{\"type\":\"choice\",\"content\":\"题目\",\"options\":[{\"key\":\"A\",\"value\":\"选项A\"}...],\"answer\":\"A\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解析\"}。编程题格式：{\"type\":\"code\",\"content\":\"题目描述\",\"answer\":\"参考答案C代码\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解析\"}";
        }

        String prompt = "你是C语言程序设计出题专家。请严格按照以下要求生成题目。\n\n"
                + "【必须遵守的铁律】\n"
                + "1. 题型：" + typeInstruction + "\n"
                + "2. 难度：" + difficulty + "（所有题目必须严格是此难度）\n"
                + "3. 数量：恰好生成" + count + "道题，不多不少\n"
                + "4. 章节范围：" + chapterName + "\n\n"
                + "【输出格式】纯JSON数组（不要```json标记，不要任何其他文字）：\n"
                + "[{\"type\":\"...\",\"content\":\"题目内容\",\"options\":[...],\"answer\":\"正确答案\",\"knowledgePoint\":\"知识点\",\"analysis\":\"解析\",\"difficulty\":\"" + difficulty + "\"}]\n\n"
                + "再次强调：必须恰好" + count + "道题，全部是" + difficulty + "难度。";

        JSONArray generated = tryGenerateQuestions(prompt, chapterName);
        if (generated == null || generated.isEmpty()) {
            return Result.error(500, "AI生成失败，请重试");
        }

        int chapterOrder = 1;
        try { chapterOrder = questionRepository.countByCourseIdAndChapterName(courseId, chapterName) / 5 + 1; } catch (Exception ignored) {}

        List<Question> saved = new ArrayList<>();
        for (int i = 0; i < generated.size(); i++) {
            JSONObject q = generated.getJSONObject(i);
            Question question = new Question();
            question.setType(q.getString("type"));
            question.setContent(q.getString("content"));
            if ("choice".equals(q.getString("type")) && q.containsKey("options")) {
                question.setOptions(q.getJSONArray("options").toJSONString());
            }
            question.setAnswer(q.getString("answer"));
            question.setKnowledgePoint(q.getString("knowledgePoint"));
            question.setAnalysis(q.getString("analysis"));
            question.setDifficulty(difficulty);
            question.setChapterName(chapterName);
            question.setChapterOrder(chapterOrder);
            question.setCourseId(courseId);
            question.setSource("ai-generated");
            saved.add(questionRepository.save(question));
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("generated", saved);
        result.put("count", saved.size());
        result.put("message", "AI已生成 " + saved.size() + " 道题目并存入题库");
        return Result.success(result);
    }

    /**
     * 选中题目布置作业 — 指定题目ID列表，直接分发给班级学生
     * body: { courseId, questionIds: [1,2,3], chapterName }
     */
    @PostMapping("/questions/assign")
    public Result<Map<String, Object>> assignQuestions(@RequestBody Map<String, Object> body) {
        Long courseId = Long.valueOf(body.get("courseId").toString());
        Long teacherId = Long.valueOf(body.getOrDefault("teacherId", "1").toString());
        @SuppressWarnings("unchecked")
        List<Integer> rawIds = (List<Integer>) body.getOrDefault("questionIds", Collections.emptyList());
        String chapterName = (String) body.getOrDefault("chapterName", "作业");
        List<Long> questionIds = rawIds.stream().map(Long::valueOf).toList();

        if (questionIds.isEmpty()) return Result.error(400, "请至少选择1道题目");

        Course course = courseRepository.findById(courseId).orElse(null);
        if (course == null) return Result.error(404, "课程不存在");

        List<Question> selectedQuestions = questionRepository.findByIdIn(questionIds);
        if (selectedQuestions.isEmpty()) return Result.error(400, "未找到有效题目");

        // 创建或更新章节
        int orderNum = chapterRepository.findByCourseIdOrderByOrderNum(courseId).size() + 1;
        Chapter chapter = chapterRepository.findByCourseIdOrderByOrderNum(courseId).stream()
                .filter(c -> c.getName().equals(chapterName)).findFirst()
                .orElseGet(() -> {
                    Chapter ch = new Chapter();
                    ch.setName(chapterName);
                    ch.setCourseId(courseId);
                    ch.setTeacherId(teacherId);
                    ch.setOrderNum(orderNum);
                    ch.setDescription("从题库选择的 " + selectedQuestions.size() + " 道题");
                    ch.setStatus("published");
                    ch.setPublishedAt(LocalDateTime.now());
                    return chapterRepository.save(ch);
                });

        // 题目JSON存入章节
        JSONArray questionArray = new JSONArray();
        for (Question q : selectedQuestions) {
            JSONObject qObj = new JSONObject();
            qObj.put("type", q.getType());
            qObj.put("content", q.getContent());
            if (q.getOptions() != null) {
                try { qObj.put("options", JSON.parseArray(q.getOptions())); } catch (Exception ignored) {}
            }
            qObj.put("answer", q.getAnswer());
            qObj.put("knowledgePoint", q.getKnowledgePoint());
            qObj.put("analysis", q.getAnalysis());
            questionArray.add(qObj);
        }
        chapter.setQuestions(questionArray.toJSONString());
        chapter.setStatus("published");
        if (chapter.getPublishedAt() == null) chapter.setPublishedAt(LocalDateTime.now());
        chapterRepository.save(chapter);

        // 分发给班级学生
        String className = course.getClassName();
        List<SysUser> students = sysUserRepository.findByClassName(className).stream()
                .filter(u -> "student".equals(u.getRole())).toList();
        int assignedCount = 0;
        for (SysUser student : students) {
            if (progressRepository.findByChapterIdAndStudentId(chapter.getId(), student.getId()).isEmpty()) {
                ChapterProgress progress = new ChapterProgress();
                progress.setChapterId(chapter.getId());
                progress.setStudentId(student.getId());
                progress.setStatus("pending");
                progressRepository.save(progress);
                assignedCount++;
            }
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("chapterId", chapter.getId());
        result.put("chapterName", chapter.getName());
        result.put("questionCount", selectedQuestions.size());
        result.put("assignedCount", assignedCount);
        result.put("message", "已布置 " + selectedQuestions.size() + " 道题给 " + assignedCount + " 名学生");
        return Result.success(result);
    }

